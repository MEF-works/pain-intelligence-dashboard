# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SQLite (default: ./data/pain.db). Required for API routes and ingest script.
# DATABASE_PATH="./data/pain.db"

# Protect /api/cron/ingest and /api/cron/ingest-dorks in production: curl must send
#   Authorization: Bearer <same value>
# Generate once on the server: openssl rand -hex 32
# Then restart the app container after changing .env.
# Do not run `source .env` in bash unless every value with spaces/special chars is quoted —
# unquoted `GITHUB_ISSUES_QUERY=is:issue ...` makes bash try to run `is:issue` as a command.
CRON_SECRET=""

# Optional: ntfy.sh (or compatible) URL for high-intensity ingest alerts.
# NTFY_URL="https://ntfy.sh/your-topic"

# Reddit global search queries (|||| separated). Default list in lib/constants/reddit-search-queries.ts
# REDDIT_SEARCH_QUERIES='"my site" not working||||"checkout not working" stripe'

# X/Twitter recent search (Bearer token). Multiple queries in TWITTER_SEARCH_QUERIES separated by ||||
# TWITTER_BEARER_TOKEN=""
# TWITTER_SEARCH_QUERIES='("checkout broken") lang:en||||("stripe issues") lang:en'

# GitHub issue search (optional token for higher rate limits)
# GITHUB_TOKEN=""
# GITHUB_ISSUES_QUERY="is:issue is:open is:public (label:bug OR label:regression)"
# Minimum repo stargazers for GitHub issues (default 5000). Set 0 to disable.
# GITHUB_MIN_STARS=5000

# Set to false to skip Gemini refinement of Action Engine fields during ingest (heuristics only).
# ACTION_ENGINE_GEMINI=false

# Serper.dev — Google search API for scripts/ingest-dorks.ts (google_dork signals).
# ingest-dorks loads .env and .env.local from the project root (dotenv).
# SERPER_API_KEY=""

# Docker / Traefik (use with docker-compose.yml)
# Public URL: https://signal.mgmalkz.com
# LETSENCRYPT_EMAIL="you@example.com"
